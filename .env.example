# Database Configuration
POSTGRES_HOST=localhost
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres_password
POSTGRES_DB=ad_sync
POSTGRES_PORT=5432

# Connection URL for Prisma / Pg
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public

# Adminer Configuration
ADMINER_PORT=8080

# Authentication & Session
SESSION_SECRET=your_session_secret_key
NODE_ENV=development

# Demo Configuration
DEMO_ADMIN_USERNAME=admin
DEMO_ADMIN_DISPLAY_NAME=Administrator
DEMO_ADMIN_EMAIL=admin@example.com
DEMO_ADMIN_PASSWORD=admin@123
DEMO_LDAP_URL=ldap://localhost
DEMO_LDAP_PORT=389
DEMO_LDAP_BIND_DN=cn=admin,dc=example,dc=org
DEMO_LDAP_BIND_PASSWORD=adminPassword
DEMO_LDAP_BASE_DN=dc=example,dc=org
DEMO_LDAP_FILTER=(objectClass=person)

# Redis Configuration
REDIS_PORT=6379
REDIS_URL=redis://localhost:6379