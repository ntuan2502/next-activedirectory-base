generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(cuid())
  dn           String    @default("")
  username     String    @unique
  displayName  String    @default("")
  firstName    String    @default("")
  lastName     String    @default("")
  email        String    @default("")
  phone        String    @default("")
  title        String    @default("")
  department   String    @default("")
  companyId    String?   @map("company_id")
  companyObj   Company?  @relation(fields: [companyId], references: [id], onDelete: SetNull)
  employeeId   String    @default("")
  manager      String    @default("")
  passwordHash String?
  disabled     Boolean   @default(false)
  lastSyncAt   DateTime?
  lastLoginAt  DateTime?
  theme        String    @default("system")
  locale       String    @default("en")
  fontSize     Int       @default(14)
  fontFamily   String    @default("sans")
  dateFormat   String    @default("YYYY-MM-DD")
  timeFormat   String    @default("24h")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  roles        Role[]
  auditLogs    AuditLog[]
  sessions     Session[]

  @@map("users")
}

model Company {
  id          String   @id @default(cuid())
  code        String   @unique // Ví dụ: ACLT, ACBH, ACHL, ATLT, ACPT
  nameVi      String   // Tên tiếng Việt: CÔNG TY CỔ PHẦN ĐÔ THỊ AMATA LONG THÀNH
  nameEn      String   // Tên tiếng Anh: AMATA CITY LONGTHANH JOINT STOCK COMPANY
  taxAddress  String   // Địa chỉ thuế
  taxCode     String   // Mã số thuế
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  users       User[]

  @@map("companies")
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  permissions String   @default("[]") // JSON string array
  isSystem    Boolean  @default(false)
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("roles")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  username  String   @default("system")
  action    String
  target    String?
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  lastActiveAt DateTime @default(now()) @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

model SystemSetting {
  id                         String    @id @default("default")
  ldapUrl                    String?
  ldapPort                   Int?
  ldapBindDn                 String?
  ldapBindPassword           String?
  ldapBaseDn                 String?
  ldapFilter                 String?
  syncEnabled                Boolean   @default(false)
  syncInterval               Int       @default(1440) // Số phút giữa mỗi lần đồng bộ, mặc định 1440 phút (24h)
  lastSyncAt                 DateTime?
  lastSyncStatus             String?   @default("none")
  lastSyncMessage            String?   @default("")
  passwordMinLength          Int       @default(8) @map("password_min_length")
  passwordPreventCommon      Boolean   @default(false) @map("password_prevent_common")
  passwordNoUserInfo         Boolean   @default(false) @map("password_no_user_info")
  passwordRequireLetter      Boolean   @default(false) @map("password_require_letter")
  passwordRequireNumber      Boolean   @default(false) @map("password_require_number")
  passwordRequireSymbol      Boolean   @default(false) @map("password_require_symbol")
  passwordRequireMixedCase   Boolean   @default(false) @map("password_require_mixed_case")
  updatedAt                  DateTime  @updatedAt

  @@map("system_settings")
}

