generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String    @id @default(cuid())
  dn           String    @default("")
  username     String    @unique
  displayName  String    @default("")
  firstName    String    @default("")
  lastName     String    @default("")
  email        String    @default("")
  phone        String    @default("")
  title        String    @default("")
  department   String    @default("")
  company      String    @default("")
  employeeId   String    @default("")
  manager      String    @default("")
  passwordHash String?
  disabled     Boolean   @default(false)
  lastSyncAt   DateTime?
  lastLoginAt  DateTime?
  theme        String    @default("dark")
  locale       String    @default("vi")
  fontSize     Int       @default(14)
  fontFamily   String    @default("sans")
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  roles        Role[]
  auditLogs    AuditLog[]
  sessions     Session[]

  @@map("users")
}

model Role {
  id          String   @id @default(cuid())
  name        String   @unique
  description String?
  permissions String   @default("[]") // JSON string array
  isSystem    Boolean  @default(false)
  users       User[]
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@map("roles")
}

model AuditLog {
  id        String   @id @default(cuid())
  userId    String?
  username  String   @default("system")
  action    String
  target    String?
  details   String?
  ipAddress String?
  createdAt DateTime @default(now())

  user      User?    @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([action])
  @@index([createdAt])
  @@map("audit_logs")
}

model Session {
  id           String   @id @default(cuid())
  userId       String
  ipAddress    String?
  userAgent    String?
  createdAt    DateTime @default(now())
  lastActiveAt DateTime @default(now()) @updatedAt

  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("sessions")
}

